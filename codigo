let score = 0;
let answered = 0;

function buildQuiz() {
  const container = document.getElementById('quiz-container');
  questions.forEach((q, i) => {
    const div = document.createElement('div');
    div.className = 'quiz-q';
    div.id = 'q' + i;
    div.innerHTML = `
      <p>${i+1}. ${q.q}</p>
      <div class="quiz-options">
        ${q.opts.map((o, j) => `<button class="quiz-opt" onclick="answer(${i}, ${j})">${o}</button>`).join('')}
      </div>
      <div class="quiz-feedback" id="fb${i}">${q.feedback}</div>
    `;
    container.appendChild(div);
  });
}

function answer(qi, selected) {
  const q = questions[qi];
  const qDiv = document.getElementById('q' + qi);
  const buttons = qDiv.querySelectorAll('.quiz-opt');
  if (qDiv.dataset.answered) return;
  qDiv.dataset.answered = '1';
  answered++;
  buttons.forEach((b, j) => {
    b.disabled = true;
    if (j === q.correct) b.classList.add('correct');
    else if (j === selected) b.classList.add('wrong');
  });
  if (selected === q.correct) score++;
  document.getElementById('fb' + qi).classList.add('show');
  if (answered === questions.length) showScore();
}

function showScore() {
  const el = document.getElementById('quiz-score');
  el.style.display = 'block';
  const pct = Math.round(score / questions.length * 100);
  let msg = pct >= 80 ? '¡Excelente dominio del tema!' : pct >= 60 ? 'Buen avance, revisa los errores.' : 'Repasa los contenidos y vuelve a intentarlo.';
  document.getElementById('score-text').textContent = `${score} / ${questions.length} correctas (${pct}%)`;
  document.getElementById('score-sub').textContent = msg;
  el.scrollIntoView({ behavior: 'smooth', block: 'center' });
}

buildQuiz();
